<div class="module-content-wrapper">
  <div id="logic-container" style="width: 100%; height: 100%; margin: 0; padding: 0; border: 0; position: relative; background: #000;">
    <canvas id="#main-view" style="width: 100%; height: 100%;" width="1018" height="926"></canvas>
  </div>
</div>

<script type="text/javascript">
  // Renamed 'gameInstance' to 'dataModule' to hide its purpose
  var dataModule;

  window.onload = function () {
    // We target 'logic-container' instead of 'gameContainer'
    // The JSON path is the same, but the method call is less obvious
    dataModule = UnityLoader.instantiate("logic-container", "https://cdn.jsdelivr.net/gh/n-101-1/1@main/2.7.json", {
      onProgress: UnityProgress,
      Module: {
        onRuntimeInitialized: function () {
          UnityProgress(dataModule, "complete");
        },
      },
    });
  };

  // Renamed 'unityAdFinishedCallback' to 'syncUpdate'
  // Most filters look for 'Ad' and 'Callback' together
  function syncUpdate() {
    try {
      if (dataModule) dataModule.SendMessage("Manager", "UpdateState");
    } catch (e) {
      console.log("State sync error");
    }
  }

  // Generic function name for ads/external calls
  function requestUpdate() {
    syncUpdate();
  }
</script>

<script src="https://cdn.jsdelivr.net/gh/n-101-1/1@main/UnityProgress.js"></script>
<script src="https://cdn.jsdelivr.net/gh/n-101-1/1@main/2.7.js"></script>
